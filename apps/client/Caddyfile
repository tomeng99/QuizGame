:80 {
  root * /srv
  encode zstd gzip

  handle /socket.io* {
    reverse_proxy server:3001
  }

  handle /api/* {
    reverse_proxy server:3001
  }

  handle /uploads/* {
    reverse_proxy server:3001
  }

  handle /health {
    reverse_proxy server:3001
  }

  @hashedAssets path /_expo/static/*
  header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

  @entryShell {
    not path /_expo/static/* /favicon.ico
  }
  header @entryShell Cache-Control "no-cache, no-store, must-revalidate"
  header @entryShell Pragma "no-cache"
  header @entryShell Expires "0"

  try_files {path} /index.html
  file_server
}
