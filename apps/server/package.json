{
  "name": "@quizgame/server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run build -w @quizgame/contracts && tsx watch src/index.ts",
    "prebuild": "npm run build -w @quizgame/contracts",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm run build -w @quizgame/contracts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@quizgame/contracts": "0.1.0",
    "fastify": "^5.8.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
